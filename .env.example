# Template for local setup — copy to .env and fill in real values.
# .env itself is gitignored; this file (.env.example) IS meant to be committed.

# OpenAI: reserved for an optional OpenAI-based fallback. The app runs fully
# on NVIDIA NIM (chat + receipt vision) without this key set.
OPENAI_API_KEY=

# NVIDIA NIM (integrate.api.nvidia.com): used for the AI Hub text chat (POST /api/ai-chat)
# and receipt scanning (POST /api/receipt-scan, vision model).
# Model reference: https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_API_KEY=
NVIDIA_INVOKE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=minimaxai/minimax-m3
NVIDIA_RECEIPT_MODEL=nvidia/llama-3.1-nemotron-nano-vl-8b-v1

# Dedicated NVIDIA NIM model used only for proactive saving recommendations.
# Keep this separate from the AI Hub model so either can be tuned independently.
# Do not commit real keys: add the value only to your local .env / deployment secrets.
NVIDIA_RECOMMENDATIONS_API_KEY=
NVIDIA_RECOMMENDATIONS_INVOKE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_RECOMMENDATIONS_MODEL=deepseek-ai/deepseek-v4-flash

# The proactive assistant refreshes a user's financial brief when their
# movements change or after this number of hours.
PROACTIVE_INSIGHT_REFRESH_HOURS=6

# Backend/frontend wiring.
DATABASE_URL=postgresql://user:password@localhost:5432/confia
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Private receipt evidence. Images are stored in Cloud Storage; PostgreSQL only
# stores object metadata. For production, set a long random RECEIPT_ACCESS_SECRET
# and PUBLIC_API_URL to the public URL of the FastAPI/Cloud Run service.
GOOGLE_CLOUD_PROJECT=synapse-dafi
GCS_RECEIPTS_BUCKET=synapse-dafi-confia-receipts
PUBLIC_API_URL=http://localhost:8000
RECEIPT_ACCESS_SECRET=
RECEIPT_ACCESS_TTL_SECONDS=300
RECEIPT_UPLOAD_MAX_BYTES=10485760

# Supabase project metadata — only needed if using the Supabase client directly
# (storage, realtime, auth). DATABASE_URL above is what main.py actually uses.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
